# =============================================================================
# Amazon Spider — 环境变量配置模板
# =============================================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 所有变量均有合理默认值，未配置时系统仍可运行。
# =============================================================================

# ---------------------------------------------------------------------------
# MySQL 数据库配置（数据持久化）
# ---------------------------------------------------------------------------
# 是否启用 MySQL Pipeline 写入，设为 false/0/no 可仅输出 CSV
MYSQL_ENABLED=True
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=amazon_scraper

# ---------------------------------------------------------------------------
# Redis 配置（Celery 调度 & 分布式采集）
# ---------------------------------------------------------------------------
# 注意：当前 celery_config.py 中硬编码了 redis://localhost:6379/0，
# 以下变量供未来迁移至环境变量使用。
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# 代理配置
# ---------------------------------------------------------------------------
# 是否启用代理中间件（默认 True，使用 ProxyPool 自动获取免费代理）
PROXY_ENABLED=True

# 自定义付费代理（逗号分隔的代理 URL 列表）
# 系统默认使用 proxy_pool.py 从 GitHub 免费源自动获取代理，验证后使用。
# 如果你购买了付费代理，在此填入即可覆盖。
# 支持格式：http://、https://、socks5://、socks4://
# 带认证：http://username:password@proxy_host:proxy_port
# CUSTOM_PROXIES=http://user:pass@res.proxy.com:8080,socks5://10.0.0.1:1080

# ---------------------------------------------------------------------------
# 爬虫行为配置（可选覆盖 settings.py 默认值）
# ---------------------------------------------------------------------------
# 是否遵守 robots.txt。
# 重要：Amazon 的 robots.txt 禁止大多数路径的自动抓取。启 用 = True 后爬虫将
# 遵守规则，但可能无法采集任何数据。默认 False 以确保功 能可用。
# 部署前请咨询法务意见 — 无视 robots.txt 可能违反 Amazon 服务条款。
ROBOTSTXT_OBEY=False

# 是否无头模式运行浏览器（默认 True）
# HEADLESS=True

# ---------------------------------------------------------------------------
# 日志配置
# ---------------------------------------------------------------------------
# 日志级别：DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# 告警通知（可选）
# ---------------------------------------------------------------------------
# 内存超限告警邮件
# MEMUSAGE_NOTIFY_MAIL=admin@example.com

# ---------------------------------------------------------------------------
# 快速开始
# ---------------------------------------------------------------------------
# 1. 安装依赖：  pip install -r requirements.txt
# 2. 安装浏览器：playwright install chromium
# 3. 启动 Redis： redis-server
# 4. 运行爬虫：  python main.py --keyword "laptop" --pages 2
# 5. 启动调度：  python celery_tasks.py
# ---------------------------------------------------------------------------
